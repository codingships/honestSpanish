---
import { getCollection } from 'astro:content';
import BlogLayout from '../../../layouts/BlogLayout.astro';

export const prerender = false;

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  
  return posts.map(post => {
      // En Astro Content Collections con directorios, 'post.slug' a menudo incluye la carpeta
      // por ejemplo: "en/spanish-for-expats-truth" o "es/primer-post"
      
      const slugParts = post.slug.split('/');
      let lang = 'es';
      let slug = post.slug;

      if (slugParts.length > 1) {
          lang = slugParts[0];
          slug = slugParts.slice(1).join('/');
      } else if (post.data && post.data.lang) {
          lang = post.data.lang;
      }

      return {
        params: { 
            lang: lang, 
            slug: slug 
        },
        props: { post },
      };
  });
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<BlogLayout post={post} lang={Astro.params.lang as any}>
  <Content />
</BlogLayout>
