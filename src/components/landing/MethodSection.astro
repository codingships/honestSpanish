---
interface MethodColumn {
  number: string;
  title: string;
  description: string;
}

interface Props {
  headline: string;
  manifesto: string;
  closing: string;
  subtitle: string;
  columns: MethodColumn[];
}

const { headline, manifesto, closing, subtitle, columns } = Astro.props;
---
<section id="metodo" class="bg-[#006064] py-24 px-6 border-b-2 border-[#006064]">
    <div class="max-w-6xl mx-auto">
        {/* Header */}
        <div class="mb-16">
            <h2 class="font-display text-4xl lg:text-5xl text-white mb-6 leading-tight">{headline}</h2>

            <div class="max-w-md mb-12">
                <p class="text-[#E0F7FA]/70 font-mono text-sm md:text-base uppercase tracking-wide mb-4">{manifesto}</p>
                <p class="font-sans text-lg md:text-xl text-white font-bold leading-tight">{closing}</p>
            </div>

            <p class="font-sans text-xl text-[#E0F7FA] font-medium max-w-2xl">{subtitle}</p>
        </div>

        {/* 3 Columns */}
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
            {columns.map((col) => (
                <div class="relative">
                    <span class="font-display text-6xl text-white/20 mb-4 block select-none">
                        {col.number}
                    </span>
                    <h3 class="font-display text-xl text-white mb-4 uppercase tracking-wide">{col.title}</h3>
                    <p class="font-sans text-base text-[#E0F7FA] leading-relaxed">
                        {col.description}
                    </p>
                </div>
            ))}
        </div>

        <div class="mt-24 pt-12 border-t border-white/20">
        </div>
    </div>
</section>
